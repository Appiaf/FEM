function [u_rom,c] = solveROM(mu, V, A0, A1, A2, F,caseType)

    mu1 = mu(1); mu2 = mu(2)
    if caseType == 1
        A = 2*A0 + mu1*A1 + mu2*A2;
    elseif caseType == 2
        A = mu1*A0 + mu2* A1 + A2;
    else
        A = 0.1*A0 + mu*A1 + A2;
    end

    Ar = V'*A*V;
    fr = V'*F;
    
    c = Ar \ fr;
    u_rom = V*c;
end