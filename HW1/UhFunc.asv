function U_h = UhFunc(a,j,x,h,cj,N)
Uhoption =1;
if Uhoption == 1
    if j == 1
    U_h = 1/h(1)*(cj(1)*(a-x(1)));
    elseif j ==N+1
else
    if j == 1
        U_h = cj(j) * phiFunc(a,j,x,h);
    elseif j == N+1
        U_h = cj(N)* phiFunc(a,N,x,h);
    else
        U_h = cj(j-1)*phiFunc(a,j-1,x,h) + cj(j)*phiFunc(a,j,x,h);
    end
end
return
end